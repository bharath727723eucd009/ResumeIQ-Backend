# FastAPI Backend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# API Keys and secrets
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here
JWT_SECRET=your-long-random-secret-key-for-jwt-here

# Server configuration
PORT=8000
ENV=development

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/resume_analyzer

# CORS - comma-separated frontend URLs
# For local development:
ALLOWED_ORIGINS=http://localhost:3000

# For production, include your Vercel frontend URL:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-frontend.vercel.app
